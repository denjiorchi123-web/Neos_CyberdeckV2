# CyberDeck OS — environment configuration
# Copy to .env and edit for your node.
# Zero external network required — all values are LAN-local.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db?journal_mode=WAL"

# ── Mesh discovery over the direct Ethernet LAN.
MESH_INTERFACE_PREFIXES=10.0.0.,169.254.
MESH_BROADCAST_ADDRS=10.0.0.255,169.254.255.255
MESH_PEER_FALLBACK_IPS=10.0.0.100:6379

# ── Redis (presence, Socket.io pub/sub, WebRTC signaling) ────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Site URL ─────────────────────────────────────────────────────────────────
# Windows dev:   https://localhost:3000
# Pi (mDNS):     https://cyberdeck.local:3000
# Pi (static):   https://10.0.0.1:3000  (replace with your bat0 IP)
NEXT_PUBLIC_SITE_URL=https://localhost:3000

# ── FastAPI backend ───────────────────────────────────────────────────────────
# Same host as NEXT_PUBLIC_SITE_URL but on port 8000 (HTTP, loopback only)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Pi / Yocto paths ─────────────────────────────────────────────────────────
# Override on Pi if the app lives somewhere other than /opt/cyberdeck.
# Used by the terminal CWD and the file-manager root.
# CYBERDECK_HOME=/opt/cyberdeck

# ── Logging ──────────────────────────────────────────────────────────────────
# CYBERDECK_LOG_DIR=/opt/cyberdeck/private/logs
