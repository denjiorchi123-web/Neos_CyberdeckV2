# CyberDeck sudoers fragment
# Install to /etc/sudoers.d/99-cyberdeck (mode 0440, owned root:root)
#
# Allows the cyberdeck user (web server) to call specific privileged helpers
# without a password. Only exact whitelisted commands are permitted.

# Network interface configuration
cyberdeck ALL=(root) NOPASSWD: /usr/local/bin/cyberdeck-netconfig.sh

# Hostname change
cyberdeck ALL=(root) NOPASSWD: /usr/bin/hostnamectl set-hostname *
