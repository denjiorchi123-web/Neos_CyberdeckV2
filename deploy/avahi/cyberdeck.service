<?xml version="1.0" standalone='no'?>
<!--
  avahi service definition for CyberDeck.
  Installed at /etc/avahi/services/cyberdeck.service on the Pi.
  Picked up automatically by avahi-daemon — no restart needed when added.

  Two records:
   - _cyberdeck._tcp     : private service type, used by the launcher's `avahi-browse`
                          to find other CyberDeck nodes on the LAN.
   - _https._tcp         : standard HTTPS advertisement so generic network browsers
                          (Avahi Discover, Bonjour Browser, dns-sd) can see the box too.
-->
<service-group>
  <name replace-wildcards="yes">%h</name>

  <service>
    <type>_cyberdeck._tcp</type>
    <port>3000</port>
    <txt-record>version=1</txt-record>
    <txt-record>tls=true</txt-record>
    <txt-record>path=/launcher</txt-record>
  </service>

  <service>
    <type>_https._tcp</type>
    <port>3000</port>
  </service>
</service-group>
