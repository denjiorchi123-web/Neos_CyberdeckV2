# Grant the cyberdeck kiosk user direct access to input and DRM devices.
# Required for weston (DRM/KMS) and libinput (touch, mouse, keyboard) to work
# as an unprivileged user without a display manager like GDM/LightDM.

# DRM/KMS — GPU output (HDMI + DSI rendering)
SUBSYSTEM=="drm", GROUP="video", MODE="0660"

# Input devices — keyboard, mouse, touchscreen
SUBSYSTEM=="input", GROUP="input", MODE="0660"

# I2C — touch controller bus (Goodix GT9xx on Touch Display 2)
SUBSYSTEM=="i2c-dev", GROUP="i2c", MODE="0660"

# Video4Linux — camera
SUBSYSTEM=="video4linux", GROUP="video", MODE="0660"

# Framebuffer fallback
SUBSYSTEM=="graphics", KERNEL=="fb*", GROUP="video", MODE="0660"
