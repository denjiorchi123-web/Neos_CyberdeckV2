
# ─── Kiosk + boot splash (added 2026-05-20) ────────────────────────────
# The previous image was missing the kiosk browser entirely — weston launched
# but had no /usr/bin/chromium to exec. Also no Plymouth theme was installed,
# so the firmware splash + cyberdeck logo never appeared.
IMAGE_INSTALL:append = " \
    chromium-ozone-wayland \
    plymouth \
    cyberdeck-bootlogo \
    cyberdeck-power \
"
