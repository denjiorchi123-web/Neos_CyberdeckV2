generator client {
  provider      = "prisma-client-js"
  // "native" = dev host (Windows/Mac/x64 Linux).
  // linux-arm64 variants cover Pi 5 on Yocto — include both OpenSSL versions
  // so the same build works whether Yocto links OpenSSL 1.1 or 3.x.
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Profile {
  id       String @id @default(uuid())
  userId   String @unique
  name     String
  imageUrl String
  email    String
  password String @default("")

  isOnline DateTime?
  lastSeen DateTime  @default(now())

  servers  Server[]
  members  Member[]
  channels Channel[]

  communities       Community[]
  communityMembers  CommunityMember[]
  broadcastChannels BroadcastChannel[]
  broadcastFollows  BroadcastFollower[]

  mutedChats   MutedChat[]
  clearedChats ClearedChat[]
  lockedChats  LockedChat[]
  blockedUsers BlockedUser[] @relation("BlockedUsers")
  blockedBy    BlockedUser[] @relation("BlockedBy")

  pinHash          String?
  securityQuestion String?
  securityAnswer   String? // Store hash of the answer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id         String @id @default(uuid())
  name       String
  imageUrl   String
  inviteCode String @unique

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  members  Member[]
  channels Channel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  communityId String?
  community   Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)

  @@index([profileId])
  @@index([communityId])
}

model Member {
  id   String @id @default(uuid())
  role String @default("GUEST")

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  messages       Message[]
  directMessages DirectMessage[]
  groupStatus    GroupMessageStatus[]

  conversationsInitiated Conversation[] @relation("MemberOne")
  conversationsReceived  Conversation[] @relation("MemberTwo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([serverId])
}

model Channel {
  id   String @id @default(uuid())
  name String
  type String @default("TEXT")

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  serverId String
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
  @@index([serverId])
}

model Message {
  id      String @id @default(uuid())
  content String
  type    String @default("TEXT") // TEXT, IMAGE, VIDEO, AUDIO, DOCUMENT

  fileUrl      String?
  fileSize     Int?
  fileName     String?
  mimeType     String?
  thumbnailUrl String?
  mediaKey     String? // AES-GCM key (hex) for client-side E2E media decryption

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  deleted            Boolean   @default(false)
  deletedForEveryone Boolean   @default(false)
  edited             Boolean   @default(false)
  editedAt           DateTime?

  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")
  isPinned  Boolean   @default(false)

  status      String    @default("SENT") // SENT, DELIVERED, READ
  deliveredAt DateTime?
  readAt      DateTime?

  groupStatuses GroupMessageStatus[]
  edits         MessageEdit[]

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
  @@index([memberId])
  @@index([channelId, createdAt(sort: Desc)])
}

model GroupMessageStatus {
  id        String  @id @default(uuid())
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  deliveredAt DateTime?
  readAt      DateTime?

  @@unique([messageId, memberId])
}

model Conversation {
  id String @id @default(uuid())

  memberOneId String
  memberOne   Member @relation("MemberOne", fields: [memberOneId], references: [id], onDelete: Cascade)

  memberTwoId String
  memberTwo   Member @relation("MemberTwo", fields: [memberTwoId], references: [id], onDelete: Cascade)

  directMessages DirectMessage[]

  @@unique([memberOneId, memberTwoId])
  @@index([memberTwoId])
}

model DirectMessage {
  id      String @id @default(uuid())
  content String
  type    String @default("TEXT")

  fileUrl      String?
  fileSize     Int?
  fileName     String?
  mimeType     String?
  thumbnailUrl String?
  mediaKey     String? // AES-GCM key (hex) for client-side E2E media decryption

  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  deleted            Boolean   @default(false)
  deletedForEveryone Boolean   @default(false)
  edited             Boolean   @default(false)
  editedAt           DateTime?

  replyToId String?
  replyTo   DirectMessage?  @relation("DirectMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   DirectMessage[] @relation("DirectMessageReplies")
  isPinned  Boolean         @default(false)

  status      String    @default("SENT")
  deliveredAt DateTime?
  readAt      DateTime?

  edits DirectMessageEdit[]

  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([conversationId])
  @@index([conversationId, createdAt(sort: Desc)])
}

model CallHistory {
  id        String  @id @default(uuid())
  callerId  String
  calleeId  String
  channelId String? // Optional if it was a DM call
  roomId    String
  type      String  @default("audio") // audio, video

  status   String @default("ended") // active, ended, missed, rejected, busy, offline, dropped, failed
  duration Int    @default(0) // duration in seconds

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callerId])
  @@index([calleeId])
}

// Periodic WebRTC quality samples written by MediaRoom (scenario #14).
// Caller writes one row every 30s while the call is active.
model CallQualityLog {
  id            String   @id @default(uuid())
  callId        String
  packetLoss    Float    @default(0) // percent (0-100)
  jitter        Float    @default(0) // milliseconds
  roundTripTime Float    @default(0) // milliseconds
  timestamp     DateTime @default(now())

  @@index([callId])
  @@index([timestamp])
}

model MessageEdit {
  id        String   @id @default(uuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([messageId])
}

model MutedChat {
  id        String    @id @default(uuid())
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chatId    String // Can be channelId or conversationId
  expiresAt DateTime? // Null means always muted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, chatId])
  @@index([profileId])
}

model BlockedUser {
  id        String  @id @default(uuid())
  blockerId String
  blocker   Profile @relation("BlockedUsers", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   Profile @relation("BlockedBy", fields: [blockedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model ClearedChat {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chatId    String // Can be channelId or conversationId
  clearedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, chatId])
  @@index([profileId])
}

model LockedChat {
  id        String  @id @default(uuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  chatId    String // Can be channelId or conversationId

  createdAt DateTime @default(now())

  @@unique([profileId, chatId])
  @@index([profileId])
}

model DirectMessageEdit {
  id              String        @id @default(uuid())
  messageId       String
  message         DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  previousContent String
  editedAt        DateTime      @default(now())

  @@index([messageId])
}

model FileIndex {
  id         String @id @default(uuid())
  name       String
  path       String
  size       Int    @default(0)
  mimeType   String @default("application/octet-stream")
  uploaderId String
  serverId   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([uploaderId])
  @@index([serverId])
}

// ── MESH NETWORK ROUTING (Phase 1) ──────────────────────────────────────────

model Node {
  id        String   @id // e.g., "pi-a-uuid"
  hostname  String?
  ipAddress String?
  publicKey String?
  isTrusted Boolean  @default(false)
  isOnline  Boolean  @default(true)
  lastSeen  DateTime @default(now())
  hopCount  Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoutingTable {
  destinationNode String   @id
  viaNode         String
  hopCount        Int
  lastUpdated     DateTime @default(now())
}

model OutboxQueue {
  id          String   @id @default(uuid())
  destination String // node id
  payload     String
  createdAt   DateTime @default(now())
}

// ── COMMUNITIES (Groups of Groups) ──────────────────────────────────────────

model Community {
  id          String  @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // A community contains multiple Groups (which are currently 'Servers')
  groups Server[]

  // Admins and Moderators of the community
  members CommunityMember[]

  // Dedicated announcements channel
  announcementsChannelId String?           @unique
  announcementsChannel   BroadcastChannel? @relation(fields: [announcementsChannelId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model CommunityMember {
  id   String @id @default(uuid())
  role String @default("MEMBER") // ADMIN, MODERATOR, MEMBER

  communityId String
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([communityId, profileId])
  @@index([profileId])
}

// ── BROADCAST CHANNELS (WhatsApp Style) ─────────────────────────────────

model BroadcastChannel {
  id          String  @id @default(uuid())
  name        String
  description String?
  imageUrl    String?

  // Only the creator (admin) can post
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Followers (read-only)
  followers BroadcastFollower[]
  messages  BroadcastMessage[]

  community Community?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profileId])
}

model BroadcastFollower {
  id        String           @id @default(uuid())
  channelId String
  channel   BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  role String @default("FOLLOWER") // ADMIN, FOLLOWER

  createdAt DateTime @default(now())

  @@unique([channelId, profileId])
}

model BroadcastMessage {
  id      String  @id @default(uuid())
  content String
  type    String  @default("TEXT")
  fileUrl String?

  channelId String
  channel   BroadcastChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([channelId])
}

// ── USER CHAT PREFERENCES ────────────────────────────────────────────────

model ArchivedChat {
  id        String   @id @default(uuid())
  profileId String
  chatId    String // The ID of the DM, Group, Community, or Channel
  createdAt DateTime @default(now())

  @@unique([profileId, chatId])
}

model PinnedChat {
  id        String   @id @default(uuid())
  profileId String
  chatId    String // The ID of the DM, Group, Community, or Channel
  createdAt DateTime @default(now())

  @@unique([profileId, chatId])
}

// WAL Journal Table for Masterless Mesh Syncing
model Journal {
  seq         Int    @id @default(autoincrement())
  rowTable    String
  rowId       String
  operation   String // INSERT, UPDATE, DELETE
  payload     String // JSON string of the row
  vectorClock String // JSON string {"mac": count}
  originMac   String
  contentHash String
  syncedTo    String @default("{}") // JSON mapping peer MACs to acknowledged sequences

  createdAt DateTime @default(now())

  @@index([rowTable, rowId])
  @@index([originMac])
}

// Persists the local Vector Clock state
model VectorClockState {
  id        String   @id @default("local")
  clock     String // JSON string {"mac": count}
  updatedAt DateTime @updatedAt
}

// Tracks the handshake connection status between mesh nodes
model MeshPeer {
  macAddress    String    @id
  userId        String?
  status        String    @default("UNKNOWN") // UNKNOWN, PENDING_OUTGOING, PENDING_INCOMING, TRUSTED, DECLINED, BLOCKED
  hostname      String?
  ipAddress     String?
  publicName    String?
  displayName   String?
  firstSeen     DateTime  @default(now())
  lastSeen      DateTime  @default(now())
  lastHandshake DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions  PeerSession[]
  syncState SyncState?

  @@index([userId])
  @@index([publicName])
}

model MeshDevice {
  id          String   @id @default(uuid())
  ownerId     String
  macAddress  String
  deviceName  String?
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ownerId, macAddress])
  @@index([ownerId])
  @@index([macAddress])
}

model MeshBlocklist {
  macAddress String   @id
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ConnectionRequest {
  requestId   String    @id @default(uuid())
  fromNodeId  String
  toNodeId    String
  direction   String // INCOMING, OUTGOING
  status      String    @default("PENDING") // PENDING, ACCEPTED, DECLINED, IGNORED, EXPIRED, BLOCKED
  message     String?
  createdAt   DateTime  @default(now())
  respondedAt DateTime?
  expiresAt   DateTime

  @@index([direction, status])
  @@index([fromNodeId])
  @@index([toNodeId])
}

model PeerSession {
  sessionId        String    @id @default(uuid())
  peerNodeId       String
  peer             MeshPeer  @relation(fields: [peerNodeId], references: [macAddress], onDelete: Cascade)
  state            String    @default("DISCONNECTED") // DISCONNECTED, CONNECTING, CONNECTED, SYNCING, FAILED
  lastConnected    DateTime?
  lastSyncStarted  DateTime?
  lastSyncFinished DateTime?
  transportIp      String?
  transportPort    Int?

  @@index([peerNodeId])
}

model SyncState {
  peerNodeId          String   @id
  peer                MeshPeer @relation(fields: [peerNodeId], references: [macAddress], onDelete: Cascade)
  localVectorClock    String   @default("{}")
  remoteVectorClock   String   @default("{}")
  lastSentEventId     String?
  lastReceivedEventId String?
  updatedAt           DateTime @updatedAt
}

model MeshEvent {
  eventId         String   @id @default(uuid())
  originNodeId    String
  entityType      String
  entityId        String
  operation       String
  payloadJson     String
  vectorClockJson String   @default("{}")
  timestamp       DateTime @default(now())
  receivedFrom    String?
  signature       String?

  @@index([originNodeId, timestamp])
  @@index([entityType, entityId])
}
